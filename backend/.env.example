# Backend Server Configuration

# Express Port
PORT=5000

# Gemini API Model Configuration
# To upgrade the model in the future, simply change this model string (e.g. to gemini-2.5-flash or gemini-2.5-pro or whatever is current)
GEMINI_MODEL=gemini-1.5-pro

# Gemini API Keys for Rotation
# Enter your keys here. If you have fewer than 7 keys, leave the others blank.
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=
