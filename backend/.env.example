# Backend Server Configuration

# Express Port
PORT=5000

# Gemini API Model Configuration
# To upgrade the model in the future, simply change this model string (e.g. to gemini-3.5-flash or gemini-3.1-pro or whatever is current)
GEMINI_MODEL=gemini-3.5-flash

# Gemini API Keys for Rotation
# Enter your keys here. If you have fewer than 7 keys, leave the others blank.
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=

# Developer Portal Administrative Password
DEVTOOLS_ADMIN_PASSWORD=admin
